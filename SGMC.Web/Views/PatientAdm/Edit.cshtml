@model SGMC.Application.Dto.Users.PatientDto

@{
    ViewData["Title"] = "Editar Paciente";
}

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-4">
    <div class="flex justify-center">
        <div class="w-full md:w-2/3 lg:w-1/2">
            <div class="bg-white rounded-lg shadow-md overflow-hidden">
                <div class="bg-yellow-400 text-gray-900 px-6 py-4">
                    <h3 class="text-xl font-bold m-0">Editar Paciente</h3>
                </div>

                <div class="p-6">
                    @if (ViewBag.ErrorMessage != null)
                    {
                        <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded relative mb-4" role="alert">
                            @ViewBag.ErrorMessage
                            <button type="button" class="absolute top-0 right-0 px-4 py-3" data-bs-dismiss="alert" aria-label="Close">
                                <span aria-hidden="true">&times;</span>
                            </button>
                        </div>
                    }

                    <form asp-action="Edit" method="post">
                        <input type="hidden" asp-for="PatientId" />
                        <div asp-validation-summary="ModelOnly" class="text-red-600 mb-3"></div>

                        <fieldset class="border border-gray-300 p-4 rounded mb-4">
                            <legend class="w-auto px-2 text-sm font-semibold">Información Personal</legend>

                            <div class="flex flex-wrap -mx-2">
                                <div class="w-full md:w-1/2 px-2 mb-3">
                                    <label class="block text-sm font-medium text-gray-700 mb-1">Nombre Completo</label>
                                    <input type="text" class="w-full px-3 py-2 border border-gray-300 rounded-md bg-gray-100" value="@Model.FullName" readonly />
                                </div>
                                <div class="w-full md:w-1/2 px-2 mb-3">
                                    <label class="block text-sm font-medium text-gray-700 mb-1">Cédula</label>
                                    <input type="text" class="w-full px-3 py-2 border border-gray-300 rounded-md bg-gray-100" value="@Model.IdentificationNumber" readonly />
                                </div>
                            </div>

                            <div class="flex flex-wrap -mx-2">
                                <div class="w-full md:w-1/2 px-2 mb-3">
                                    <label class="block text-sm font-medium text-gray-700 mb-1">Género</label>
                                    <input type="text" class="w-full px-3 py-2 border border-gray-300 rounded-md bg-gray-100" value="@(Model.Gender == "M" ? "Masculino" : "Femenino")" readonly />
                                </div>
                                <div class="w-full md:w-1/2 px-2 mb-3">
                                    <label class="block text-sm font-medium text-gray-700 mb-1">Tipo de Sangre</label>
                                    <input type="text" class="w-full px-3 py-2 border border-gray-300 rounded-md bg-gray-100" value="@Model.BloodType" readonly />
                                </div>
                            </div>
                        </fieldset>

                        <fieldset class="border border-gray-300 p-4 rounded mb-4">
                            <legend class="w-auto px-2 text-sm font-semibold">Información de Contacto</legend>

                            <div class="flex flex-wrap -mx-2">
                                <div class="w-full md:w-1/2 px-2 mb-3">
                                    <label asp-for="PhoneNumber" class="block text-sm font-medium text-gray-700 mb-1">Teléfono</label>
                                    <input asp-for="PhoneNumber" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-yellow-400 focus:border-transparent" placeholder="XXX-XXX-XXXX" />
                                    <span asp-validation-for="PhoneNumber" class="text-red-600 text-sm"></span>
                                </div>
                                <div class="w-full md:w-1/2 px-2 mb-3">
                                    <label asp-for="Email" class="block text-sm font-medium text-gray-700 mb-1">Email</label>
                                    <input asp-for="Email" type="email" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-yellow-400 focus:border-transparent" />
                                    <span asp-validation-for="Email" class="text-red-600 text-sm"></span>
                                </div>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Address" class="block text-sm font-medium text-gray-700 mb-1">Dirección</label>
                                <textarea asp-for="Address" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-yellow-400 focus:border-transparent" rows="2"></textarea>
                                <span asp-validation-for="Address" class="text-red-600 text-sm"></span>
                            </div>
                        </fieldset>

                        <fieldset class="border border-gray-300 p-4 rounded mb-4">
                            <legend class="w-auto px-2 text-sm font-semibold">Contacto de Emergencia</legend>

                            <div class="flex flex-wrap -mx-2">
                                <div class="w-full md:w-1/2 px-2 mb-3">
                                    <label asp-for="EmergencyContactName" class="block text-sm font-medium text-gray-700 mb-1">Nombre del Contacto</label>
                                    <input asp-for="EmergencyContactName" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-yellow-400 focus:border-transparent" />
                                    <span asp-validation-for="EmergencyContactName" class="text-red-600 text-sm"></span>
                                </div>
                                <div class="w-full md:w-1/2 px-2 mb-3">
                                    <label asp-for="EmergencyContactPhone" class="block text-sm font-medium text-gray-700 mb-1">Teléfono de Emergencia</label>
                                    <input asp-for="EmergencyContactPhone" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-yellow-400 focus:border-transparent" placeholder="XXX-XXX-XXXX" />
                                    <span asp-validation-for="EmergencyContactPhone" class="text-red-600 text-sm"></span>
                                </div>
                            </div>
                        </fieldset>

                        <fieldset class="border border-gray-300 p-4 rounded mb-4">
                            <legend class="w-auto px-2 text-sm font-semibold">Información Médica</legend>

                            <div class="flex flex-wrap -mx-2">
                                <div class="w-full md:w-1/2 px-2 mb-3">
                                    <label asp-for="Allergies" class="block text-sm font-medium text-gray-700 mb-1">Alergias</label>
                                    <textarea asp-for="Allergies" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-yellow-400 focus:border-transparent" rows="2"></textarea>
                                    <span asp-validation-for="Allergies" class="text-red-600 text-sm"></span>
                                </div>
                                <div class="w-full md:w-1/2 px-2 mb-3">
                                    <label asp-for="InsuranceProviderId" class="block text-sm font-medium text-gray-700 mb-1">Proveedor de Seguro</label>
                                    <select asp-for="InsuranceProviderId" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-yellow-400 focus:border-transparent">
                                        <option value="">-- Seleccione --</option>
                                        @if (ViewBag.InsuranceProviders != null)
                                        {
                                            @foreach (var provider in ViewBag.InsuranceProviders)
                                            {
                                                <option value="@provider.InsuranceProviderId"
                                                        selected="@(provider.InsuranceProviderId == Model.InsuranceProviderId)">
                                                    @provider.Name
                                                </option>
                                            }
                                        }
                                    </select>
                                    <span asp-validation-for="InsuranceProviderId" class="text-red-600 text-sm"></span>
                                </div>
                            </div>
                        </fieldset>

                        <div class="grid gap-2 md:flex md:justify-end">
                            <a asp-action="Index" class="bg-gray-500 hover:bg-gray-600 text-white font-semibold py-2 px-4 rounded-md transition duration-200 text-center">
                                <i class="bi bi-arrow-left"></i> Cancelar
                            </a>
                            <button type="submit" class="bg-yellow-400 hover:bg-yellow-500 text-gray-900 font-semibold py-2 px-4 rounded-md transition duration-200">
                                <i class="bi bi-save"></i> Actualizar Paciente
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}