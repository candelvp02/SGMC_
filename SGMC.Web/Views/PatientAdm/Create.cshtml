@model SGMC.Application.Dto.Users.RegisterPatientDto

@{
    ViewData["Title"] = "Crear Paciente";
}

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-4">
    <div class="flex justify-center">
        <div class="w-full md:w-2/3 lg:w-1/2">
            <div class="bg-white rounded-lg shadow-md overflow-hidden">
                <div class="bg-blue-600 text-white px-6 py-4">
                    <h3 class="text-xl font-bold m-0">Crear Nuevo Paciente</h3>
                </div>

                <div class="p-6">
                    @if (ViewBag.ErrorMessage != null)
                    {
                        <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded relative mb-4" role="alert">
                            @ViewBag.ErrorMessage
                            <button type="button" class="absolute top-0 right-0 px-4 py-3" data-bs-dismiss="alert" aria-label="Close">
                                <span aria-hidden="true">&times;</span>
                            </button>
                        </div>
                    }

                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-red-600 mb-3"></div>

                        <fieldset class="border border-gray-300 p-4 rounded mb-4">
                            <legend class="w-auto px-2 text-sm font-semibold">Información Personal</legend>

                            <div class="flex flex-wrap -mx-2">
                                <div class="w-full md:w-1/2 px-2 mb-3">
                                    <label asp-for="FirstName" class="block text-sm font-medium text-gray-700 mb-1">Nombre</label>
                                    <input asp-for="FirstName" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent" placeholder="Ej: Juan" />
                                    <span asp-validation-for="FirstName" class="text-red-600 text-sm"></span>
                                </div>
                                <div class="w-full md:w-1/2 px-2 mb-3">
                                    <label asp-for="LastName" class="block text-sm font-medium text-gray-700 mb-1">Apellido</label>
                                    <input asp-for="LastName" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent" placeholder="Ej: Pérez" />
                                    <span asp-validation-for="LastName" class="text-red-600 text-sm"></span>
                                </div>
                            </div>

                            <div class="flex flex-wrap -mx-2">
                                <div class="w-full md:w-1/2 px-2 mb-3">
                                    <label asp-for="IdentificationNumber" class="block text-sm font-medium text-gray-700 mb-1">Cédula</label>
                                    <input asp-for="IdentificationNumber" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent" placeholder="XXX-XXXXXXX-X" />
                                    <span asp-validation-for="IdentificationNumber" class="text-red-600 text-sm"></span>
                                    <small class="block text-gray-500 text-xs mt-1">Formato: 001-0000001-1</small>
                                </div>
                                <div class="w-full md:w-1/2 px-2 mb-3">
                                    <label asp-for="DateOfBirth" class="block text-sm font-medium text-gray-700 mb-1">Fecha de Nacimiento</label>
                                    <input asp-for="DateOfBirth" type="date" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent" />
                                    <span asp-validation-for="DateOfBirth" class="text-red-600 text-sm"></span>
                                </div>
                            </div>

                            <div class="flex flex-wrap -mx-2">
                                <div class="w-full md:w-1/2 px-2 mb-3">
                                    <label asp-for="Gender" class="block text-sm font-medium text-gray-700 mb-1">Género</label>
                                    <select asp-for="Gender" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent">
                                        <option value="">-- Seleccione --</option>
                                        <option value="M">Masculino</option>
                                        <option value="F">Femenino</option>
                                    </select>
                                    <span asp-validation-for="Gender" class="text-red-600 text-sm"></span>
                                </div>
                                <div class="w-full md:w-1/2 px-2 mb-3">
                                    <label asp-for="BloodType" class="block text-sm font-medium text-gray-700 mb-1">Tipo de Sangre</label>
                                    <select asp-for="BloodType" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent">
                                        <option value="">-- Seleccione --</option>
                                        <option value="A+">A+</option>
                                        <option value="A-">A-</option>
                                        <option value="B+">B+</option>
                                        <option value="B-">B-</option>
                                        <option value="AB+">AB+</option>
                                        <option value="AB-">AB-</option>
                                        <option value="O+">O+</option>
                                        <option value="O-">O-</option>
                                    </select>
                                    <span asp-validation-for="BloodType" class="text-red-600 text-sm"></span>
                                </div>
                            </div>
                        </fieldset>

                        <fieldset class="border border-gray-300 p-4 rounded mb-4">
                            <legend class="w-auto px-2 text-sm font-semibold">Información de Contacto</legend>

                            <div class="flex flex-wrap -mx-2">
                                <div class="w-full md:w-1/2 px-2 mb-3">
                                    <label asp-for="PhoneNumber" class="block text-sm font-medium text-gray-700 mb-1">Teléfono</label>
                                    <input asp-for="PhoneNumber" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent" placeholder="XXX-XXX-XXXX" />
                                    <span asp-validation-for="PhoneNumber" class="text-red-600 text-sm"></span>
                                    <small class="block text-gray-500 text-xs mt-1">Formato: 809-123-4567</small>
                                </div>
                                <div class="w-full md:w-1/2 px-2 mb-3">
                                    <label asp-for="Email" class="block text-sm font-medium text-gray-700 mb-1">Email</label>
                                    <input asp-for="Email" type="email" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent" placeholder="ejemplo@correo.com" />
                                    <span asp-validation-for="Email" class="text-red-600 text-sm"></span>
                                </div>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Address" class="block text-sm font-medium text-gray-700 mb-1">Dirección</label>
                                <textarea asp-for="Address" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent" rows="2" placeholder="Dirección completa"></textarea>
                                <span asp-validation-for="Address" class="text-red-600 text-sm"></span>
                            </div>
                        </fieldset>

                        <fieldset class="border border-gray-300 p-4 rounded mb-4">
                            <legend class="w-auto px-2 text-sm font-semibold">Contacto de Emergencia</legend>

                            <div class="flex flex-wrap -mx-2">
                                <div class="w-full md:w-1/2 px-2 mb-3">
                                    <label asp-for="EmergencyContactName" class="block text-sm font-medium text-gray-700 mb-1">Nombre del Contacto</label>
                                    <input asp-for="EmergencyContactName" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent" />
                                    <span asp-validation-for="EmergencyContactName" class="text-red-600 text-sm"></span>
                                </div>
                                <div class="w-full md:w-1/2 px-2 mb-3">
                                    <label asp-for="EmergencyContactPhone" class="block text-sm font-medium text-gray-700 mb-1">Teléfono de Emergencia</label>
                                    <input asp-for="EmergencyContactPhone" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent" placeholder="XXX-XXX-XXXX" />
                                    <span asp-validation-for="EmergencyContactPhone" class="text-red-600 text-sm"></span>
                                </div>
                            </div>
                        </fieldset>

                        <fieldset class="border border-gray-300 p-4 rounded mb-4">
                            <legend class="w-auto px-2 text-sm font-semibold">Información Médica</legend>

                            <div class="flex flex-wrap -mx-2">
                                <div class="w-full md:w-1/2 px-2 mb-3">
                                    <label asp-for="Allergies" class="block text-sm font-medium text-gray-700 mb-1">Alergias</label>
                                    <textarea asp-for="Allergies" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent" rows="2" placeholder="Ingrese alergias conocidas"></textarea>
                                    <span asp-validation-for="Allergies" class="text-red-600 text-sm"></span>
                                </div>
                                <div class="w-full md:w-1/2 px-2 mb-3">
                                    <label asp-for="InsuranceProviderId" class="block text-sm font-medium text-gray-700 mb-1">Proveedor de Seguro</label>
                                    <select asp-for="InsuranceProviderId" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent">
                                        <option value="">-- Seleccione --</option>
                                        @if (ViewBag.InsuranceProviders != null)
                                        {
                                            @foreach (var provider in ViewBag.InsuranceProviders)
                                            {
                                                <option value="@provider.InsuranceProviderId">@provider.Name</option>
                                            }
                                        }
                                    </select>
                                    <span asp-validation-for="InsuranceProviderId" class="text-red-600 text-sm"></span>
                                </div>
                            </div>
                        </fieldset>

                        <fieldset class="border border-gray-300 p-4 rounded mb-4">
                            <legend class="w-auto px-2 text-sm font-semibold">Credenciales de Acceso</legend>

                            <div class="mb-3">
                                <label asp-for="Password" class="block text-sm font-medium text-gray-700 mb-1">Contraseña</label>
                                <input asp-for="Password" type="password" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent" />
                                <span asp-validation-for="Password" class="text-red-600 text-sm"></span>
                                <small class="block text-gray-500 text-xs mt-1">Mínimo 8 caracteres, debe incluir mayúsculas, minúsculas y números</small>
                            </div>
                        </fieldset>

                        <div class="grid gap-2 md:flex md:justify-end">
                            <a asp-action="Index" class="bg-gray-500 hover:bg-gray-600 text-white font-semibold py-2 px-4 rounded-md transition duration-200 text-center">
                                <i class="bi bi-arrow-left"></i> Cancelar
                            </a>
                            <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2 px-4 rounded-md transition duration-200">
                                <i class="bi bi-save"></i> Guardar Paciente
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}