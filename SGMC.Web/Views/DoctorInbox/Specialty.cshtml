@{
    ViewData["Title"] = "Mi Especialidad";
}

<div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

    <div class="mb-8">
        <h1 class="text-3xl font-bold text-gray-900">Mi Especialidad</h1>
        <p class="text-gray-600 mt-2">Selecciona tu especialidad médica para que los pacientes puedan encontrarte</p>
    </div>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="mb-4 bg-red-100 border-l-4 border-red-500 text-red-700 p-4 rounded-lg shadow-sm">
            <div class="flex items-center">
                <i class="fas fa-exclamation-circle mr-2 text-red-500"></i>
                <span>@TempData["ErrorMessage"]</span>
            </div>
        </div>
    }

    <!-- Especialidad actual -->
    <div class="mb-6 bg-blue-50 border border-blue-200 rounded-lg p-4">
        <div class="flex items-start">
            <i class="fas fa-stethoscope text-blue-500 mt-0.5 mr-3"></i>
            <div>
                <h4 class="text-sm font-semibold text-blue-800">Especialidad actual</h4>
                <p class="text-sm text-blue-600 mt-1">
                    @(string.IsNullOrEmpty(ViewBag.CurrentSpecialtyName?.ToString()) ? "Sin especialidad asignada" : ViewBag.CurrentSpecialtyName)
                </p>
            </div>
        </div>
    </div>

    <!-- Formulario -->
    <div class="bg-white rounded-xl shadow-lg overflow-hidden">
        <div class="border-b border-gray-200 bg-gray-50 px-6 py-4">
            <h3 class="text-lg font-semibold text-gray-900">
                <i class="fas fa-pen-alt mr-2 text-blue-600"></i>
                Cambiar Especialidad
            </h3>
        </div>

        <div class="p-6">
            <form asp-action="Specialty" method="post">
                @Html.AntiForgeryToken()

                <div class="mb-6">
                    <label class="block text-sm font-medium text-gray-700 mb-2">
                        Especialidad
                        <span class="text-red-500 ml-1">*</span>
                    </label>
                    <select name="specialtyId"
                            class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition"
                            required>
                        <option value="">Seleccione una especialidad...</option>
                        @foreach (var specialty in ViewBag.Specialties as IEnumerable<SGMC.Application.Dto.Medical.SpecialtyDto> ?? new List<SGMC.Application.Dto.Medical.SpecialtyDto>())
                        {
                            @if (specialty.SpecialtyId == ViewBag.CurrentSpecialtyId)
                            {
                                <option value="@specialty.SpecialtyId" selected>@specialty.SpecialtyName</option>
                            }
                            else
                            {
                                <option value="@specialty.SpecialtyId">@specialty.SpecialtyName</option>
                            }
                        }
                    </select>
                    <p class="text-xs text-gray-500 mt-1">Solo se muestran especialidades activas en el sistema</p>
                </div>

                <div class="flex flex-wrap gap-3 pt-4 border-t border-gray-200">
                    <button type="submit"
                            class="inline-flex items-center px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white font-medium rounded-lg transition duration-200 shadow-md">
                        <i class="fas fa-save mr-2"></i>
                        Guardar Especialidad
                    </button>
                    <a asp-action="Index"
                       class="inline-flex items-center px-4 py-2 bg-gray-500 hover:bg-gray-600 text-white font-medium rounded-lg transition duration-200 shadow-md">
                        <i class="fas fa-times mr-2"></i>
                        Cancelar
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
}