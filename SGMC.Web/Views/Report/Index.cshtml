@using SGMC.Web.Models
@using SGMC.Web.Models.Report
@model ReportViewModel
@{
    ViewData["Title"] = "Reportes y Estadísticas";
}

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Título -->
    <div class="mb-8">
        <div class="flex items-center gap-3 mb-2">
            <i class="fas fa-chart-line text-3xl text-blue-600"></i>
            <h1 class="text-3xl font-bold text-gray-900">Reportes y Estadísticas</h1>
        </div>
        <p class="text-gray-600">Panel de estadísticas y generación de reportes de citas.</p>
    </div>

    <!-- Mensajes de error -->
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="mb-4 bg-red-100 border-l-4 border-red-500 text-red-700 p-4 rounded-lg shadow-sm">
            <div class="flex items-center">
                <i class="fas fa-exclamation-circle mr-2 text-red-500"></i>
                <span>@TempData["ErrorMessage"]</span>
            </div>
        </div>
    }

    @if (ViewBag.ErrorMessage != null)
    {
        <div class="mb-4 bg-red-100 border-l-4 border-red-500 text-red-700 p-4 rounded-lg shadow-sm">
            <div class="flex items-center">
                <i class="fas fa-exclamation-circle mr-2 text-red-500"></i>
                <span>@ViewBag.ErrorMessage</span>
            </div>
        </div>
    }

    <!-- Tarjetas de Estadísticas -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
        <!-- Total Citas -->
        <div class="bg-gradient-to-br from-blue-500 to-blue-600 rounded-xl shadow-lg overflow-hidden">
            <div class="p-6">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-blue-100 text-sm font-medium uppercase tracking-wide">Citas Totales</p>
                        <p class="text-white text-3xl font-bold mt-2">@Model.Statistics?.TotalAppointments</p>
                    </div>
                    <div class="bg-white/20 rounded-lg p-3">
                        <i class="fas fa-calendar-alt text-white text-2xl"></i>
                    </div>
                </div>
            </div>
        </div>

        <!-- Confirmadas -->
        <div class="bg-gradient-to-br from-green-500 to-green-600 rounded-xl shadow-lg overflow-hidden">
            <div class="p-6">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-green-100 text-sm font-medium uppercase tracking-wide">Confirmadas</p>
                        <p class="text-white text-3xl font-bold mt-2">@Model.Statistics?.ConfirmedAppointments</p>
                    </div>
                    <div class="bg-white/20 rounded-lg p-3">
                        <i class="fas fa-check-circle text-white text-2xl"></i>
                    </div>
                </div>
            </div>
        </div>

        <!-- Pendientes -->
        <div class="bg-gradient-to-br from-yellow-500 to-yellow-600 rounded-xl shadow-lg overflow-hidden">
            <div class="p-6">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-yellow-100 text-sm font-medium uppercase tracking-wide">Pendientes</p>
                        <p class="text-white text-3xl font-bold mt-2">@Model.Statistics?.PendingAppointments</p>
                    </div>
                    <div class="bg-white/20 rounded-lg p-3">
                        <i class="fas fa-clock text-white text-2xl"></i>
                    </div>
                </div>
            </div>
        </div>

        <!-- Canceladas -->
        <div class="bg-gradient-to-br from-red-500 to-red-600 rounded-xl shadow-lg overflow-hidden">
            <div class="p-6">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-red-100 text-sm font-medium uppercase tracking-wide">Canceladas</p>
                        <p class="text-white text-3xl font-bold mt-2">@Model.Statistics?.CancelledAppointments</p>
                    </div>
                    <div class="bg-white/20 rounded-lg p-3">
                        <i class="fas fa-times-circle text-white text-2xl"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Card de Generación de Reportes -->
    <div class="bg-white rounded-xl shadow-lg overflow-hidden">
        <div class="border-b border-gray-200 bg-gray-50 px-6 py-4">
            <h3 class="text-lg font-semibold text-gray-900">Generar Reporte</h3>
        </div>

        <div class="p-6">
            <!-- Formulario de Filtros -->
            <form asp-action="Index" method="get">
                <h5 class="text-md font-semibold text-gray-700 mb-4">Filtrar Estadísticas y Resultados</h5>

                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
                    <div>
                        <label asp-for="Filter.StartDate" class="block text-sm font-medium text-gray-700 mb-2">Desde</label>
                        <input asp-for="Filter.StartDate" type="date"
                               class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent" />
                    </div>

                    <div>
                        <label asp-for="Filter.EndDate" class="block text-sm font-medium text-gray-700 mb-2">Hasta</label>
                        <input asp-for="Filter.EndDate" type="date"
                               class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent" />
                    </div>

                    <div>
                        <label asp-for="Filter.DoctorId" class="block text-sm font-medium text-gray-700 mb-2">Doctor</label>
                        <select asp-for="Filter.DoctorId"
                                class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent">
                            <option value="">-- Todos los Doctores --</option>
                            @if (Model.Doctors != null)
                            {
                                @foreach (var doctor in Model.Doctors)
                                {
                                    <option value="@doctor.DoctorId">@doctor.DisplayText</option>
                                }
                            }
                        </select>
                    </div>

                    <div>
                        <label asp-for="Filter.StatusId" class="block text-sm font-medium text-gray-700 mb-2">Estado</label>
                        <select asp-for="Filter.StatusId"
                                class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent">
                            <option value="">-- Todos los Estados --</option>
                            @if (Model.Statuses != null)
                            {
                                @foreach (var status in Model.Statuses)
                                {
                                    <option value="@status.StatusId">@status.StatusName</option>
                                }
                            }
                        </select>
                    </div>
                </div>

                <div class="flex justify-end">
                    <button type="submit" class="inline-flex items-center px-4 py-2 bg-info-500 hover:bg-info-600 text-white font-medium rounded-lg transition shadow-sm">
                        <i class="fas fa-filter mr-2"></i>
                        Filtrar
                    </button>
                </div>
            </form>

            <hr class="my-6 border-gray-200" />

            <!-- Resultados del Filtro -->
            <div class="mt-4">
                <h4 class="text-lg font-semibold text-gray-800 mb-4">Resultados del Filtro</h4>

                @if (Model.FilteredAppointments != null && Model.FilteredAppointments.Any())
                {
                    <div class="overflow-x-auto">
                        <table class="min-w-full divide-y divide-gray-200">
                            <thead class="bg-gray-50">
                                <tr>
                                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Fecha y Hora</th>
                                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Paciente</th>
                                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Doctor</th>
                                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Estado</th>
                                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"></th>
                                </tr>
                            </thead>
                            <tbody class="bg-white divide-y divide-gray-200">
                                @foreach (var cita in Model.FilteredAppointments)
                                {
                                    <tr class="hover:bg-gray-50 transition">
                                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                                            @cita.AppointmentDate.ToString("g")
                                        </td>
                                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-700">
                                            @cita.PatientName
                                        </td>
                                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-700">
                                            @cita.DoctorName
                                        </td>
                                        <td class="px-6 py-4 whitespace-nowrap">
                                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium
                                                        @(cita.StatusColor == "success" ? "bg-green-100 text-green-800" :
                                                                                                    cita.StatusColor == "warning" ? "bg-yellow-100 text-yellow-800" :
                                                                                                    cita.StatusColor == "danger" ? "bg-red-100 text-red-800" :
                                                                                                    "bg-gray-100 text-gray-800")">
                                        @cita.StatusName
                                    </span>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm">
                                    @* <a asp-controller="AppointmentAdm" asp-action="Details" asp-route-id="@cita.AppointmentId" 
                                               class="text-blue-600 hover:text-blue-800 transition">
                                                <i class="fas fa-eye"></i>
                                            </a> *@
                                        </td>
                                    </tr>
                                                        }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="bg-gray-50 border border-gray-200 rounded-lg p-8 text-center">
                        <i class="fas fa-calendar-times text-4xl text-gray-400 mb-3 block"></i>
                        <p class="text-gray-500">No se encontraron citas con los filtros seleccionados.</p>
                    </div>
                }
            </div>

            <hr class="my-6 border-gray-200" />

            <!-- Descargar Reporte -->
            <form asp-action="GeneratePdfReport" method="post" class="mt-4">
                <h5 class="text-md font-semibold text-gray-700 mb-3">Descargar Reporte</h5>

                <input type="hidden" asp-for="Filter.StartDate" />
                <input type="hidden" asp-for="Filter.EndDate" />
                <input type="hidden" asp-for="Filter.DoctorId" />
                <input type="hidden" asp-for="Filter.PatientId" />
                <input type="hidden" asp-for="Filter.StatusId" />

                <p class="text-gray-600 mb-4">Descargue un reporte detallado basado en los filtros seleccionados arriba.</p>

                <div class="flex flex-wrap gap-3">
                    <button type="submit" class="inline-flex items-center px-4 py-2 bg-red-600 hover:bg-red-700 text-white font-medium rounded-lg transition shadow-sm">
                        <i class="fas fa-file-pdf mr-2"></i>
                        Generar PDF
                    </button>

                    <button type="submit" class="inline-flex items-center px-4 py-2 bg-green-600 hover:bg-green-700 text-white font-medium rounded-lg transition shadow-sm"
                            asp-action="GenerateExcelReport">
                        <i class="fas fa-file-excel mr-2"></i>
                        Generar Excel
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        .bg-info-500 {
            background-color: #0dcaf0;
        }

        .bg-info-600:hover {
            background-color: #0bb5d8;
        }
    </style>
}