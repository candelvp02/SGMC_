@model IEnumerable<SGMC.Application.Dto.Insurance.InsuranceProviderDto>

@{
    ViewData["Title"] = "Proveedores de Seguro";
}

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

    <div class="mb-8">
        <h1 class="text-3xl font-bold text-gray-900">Proveedores de Seguro</h1>
        <p class="text-gray-600 mt-2">Administra los proveedores de seguro médico disponibles</p>
    </div>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="mb-4 bg-red-100 border-l-4 border-red-500 text-red-700 p-4 rounded-lg shadow-sm">
            <div class="flex items-center">
                <i class="fas fa-exclamation-circle mr-2 text-red-500"></i>
                <span>@TempData["ErrorMessage"]</span>
            </div>
        </div>
    }
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="mb-4 bg-green-100 border-l-4 border-green-500 text-green-700 p-4 rounded-lg shadow-sm">
            <div class="flex items-center">
                <i class="fas fa-check-circle mr-2 text-green-500"></i>
                <span>@TempData["SuccessMessage"]</span>
            </div>
        </div>
    }

    <div class="mb-6 flex justify-end">
        <a asp-action="Create"
           class="inline-flex items-center px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white font-medium rounded-lg transition duration-200 shadow-md">
            <i class="fas fa-plus mr-2"></i>
            Nuevo Proveedor
        </a>
    </div>

    <div class="bg-white rounded-xl shadow-lg overflow-hidden">
        <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-gray-200">
                <thead class="bg-gray-800 text-white">
                    <tr>
                        <th class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wider">Nombre</th>
                        <th class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wider">Tipo de Red</th>
                        <th class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wider">Preferencial</th>
                        <th class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wider">Estado</th>
                        <th class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wider">Fecha Creación</th>
                        <th class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wider">Última Actualización</th>
                        <th class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wider">Acciones</th>
                    </tr>
                </thead>
                <tbody class="bg-white divide-y divide-gray-200">
                    @foreach (var provider in Model)
                    {
                        <tr class="hover:bg-gray-50 transition duration-150">
                            <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">
                                <div class="flex items-center gap-2">
                                    @if (!string.IsNullOrEmpty(provider.LogoUrl))
                                    {
                                        <img src="@provider.LogoUrl" alt="@provider.Name" class="w-8 h-8 rounded object-contain" onerror="this.style.display='none'" />
                                    }
                                    else
                                    {
                                        <div class="w-8 h-8 rounded bg-blue-100 flex items-center justify-center">
                                            <i class="fas fa-shield-alt text-blue-600 text-xs"></i>
                                        </div>
                                    }
                                    @provider.Name
                                </div>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-700">
                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800">
                                    @provider.NetworkTypeName
                                </span>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-700">
                                @if (provider.IsPreferred)
                                {
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800">
                                        <i class="fas fa-star mr-1"></i>
                                        Preferencial
                                    </span>
                                }
                                else
                                {
                                    <span class="text-gray-400 text-xs">—</span>
                                }
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap">
                                @if (provider.IsActive)
                                {
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                                        <span class="w-1.5 h-1.5 bg-green-500 rounded-full mr-1.5"></span>
                                        Activo
                                    </span>
                                }
                                else
                                {
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800">
                                        <span class="w-1.5 h-1.5 bg-red-500 rounded-full mr-1.5"></span>
                                        Inactivo
                                    </span>
                                }
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-700">
                                <div class="flex items-center">
                                    <i class="fas fa-calendar-alt text-gray-400 mr-2"></i>
                                    @provider.CreatedAt.ToString("dd/MM/yyyy")
                                </div>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-700">
                                <div class="flex items-center">
                                    <i class="fas fa-clock text-gray-400 mr-2"></i>
                                    @(provider.UpdatedAt?.ToString("dd/MM/yyyy") ?? "—")
                                </div>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm">
                                <div class="flex flex-wrap gap-2">
                                    <a asp-action="Details" asp-route-id="@provider.InsuranceProviderId"
                                       class="inline-flex items-center px-2.5 py-1.5 bg-blue-500 hover:bg-blue-600 text-white text-xs font-medium rounded transition">
                                        <i class="fas fa-info-circle mr-1"></i>
                                        Detalles
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@provider.InsuranceProviderId"
                                       class="inline-flex items-center px-2.5 py-1.5 bg-yellow-500 hover:bg-yellow-600 text-white text-xs font-medium rounded transition">
                                        <i class="fas fa-edit mr-1"></i>
                                        Editar
                                    </a>
                                    @if (provider.IsActive)
                                    {
                                        <form asp-action="Deactivate" method="post" style="display:inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@provider.InsuranceProviderId" />
                                            <button type="submit"
                                                    class="inline-flex items-center px-2.5 py-1.5 bg-red-500 hover:bg-red-600 text-white text-xs font-medium rounded transition"
                                                    onclick="return confirm('¿Desactivar @provider.Name?')">
                                                <i class="fas fa-ban mr-1"></i>
                                                Desactivar
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <form asp-action="Activate" method="post" style="display:inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@provider.InsuranceProviderId" />
                                            <button type="submit"
                                                    class="inline-flex items-center px-2.5 py-1.5 bg-green-500 hover:bg-green-600 text-white text-xs font-medium rounded transition">
                                                <i class="fas fa-check mr-1"></i>
                                                Reactivar
                                            </button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (!Model.Any())
        {
            <div class="text-center py-12 bg-gray-50">
                <i class="fas fa-shield-alt text-5xl text-gray-400 mb-3 block"></i>
                <p class="text-gray-500 text-lg">No hay proveedores registrados</p>
                <p class="text-gray-400 text-sm mt-1">Comienza creando un nuevo proveedor de seguro</p>
            </div>
        }
    </div>

    @if (Model.Any())
    {
        <div class="mt-4 text-sm text-gray-600 flex items-center justify-between">
            <div>
                <i class="fas fa-database mr-1"></i>
                Total: <span class="font-semibold">@Model.Count()</span>
            </div>
            <div>
                Activos: <span class="font-semibold text-green-600">@Model.Count(p => p.IsActive)</span>
                | Inactivos: <span class="font-semibold text-red-600">@Model.Count(p => !p.IsActive)</span>
            </div>
        </div>
    }
</div>

@section Styles {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
}