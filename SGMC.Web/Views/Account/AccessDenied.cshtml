@{
    ViewData["Title"] = "Acceso Denegado";
}

<div class="max-w-2xl mx-auto px-4 py-16 text-center">
    <i class="fas fa-ban text-red-500 text-6xl mb-6"></i>
    <h1 class="text-3xl font-bold text-gray-900 mb-3">Acceso Denegado</h1>
    <p class="text-gray-600 mb-8">
        No tienes permisos para acceder a esta sección.
        Esta área es exclusiva para administradores del sistema.
    </p>
    <a asp-controller="Home" asp-action="Index"
       class="inline-flex items-center px-6 py-3 bg-blue-600 hover:bg-blue-700 text-white font-medium rounded-lg transition duration-200 shadow-md">
        <i class="fas fa-home mr-2"></i>
        Volver al Inicio
    </a>
</div>

@section Styles {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
}