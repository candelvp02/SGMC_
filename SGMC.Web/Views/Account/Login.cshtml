@model SGMC.Application.Dto.System.LoginDto

@{
    ViewData["Title"] = "Iniciar Sesión";
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login — HealtSync</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body class="bg-gray-100 min-h-screen flex items-center justify-center">

    <div class="w-full max-w-md">

        <!-- Logo / Brand -->
        <div class="text-center mb-8">
            <i class="fas fa-heartbeat text-blue-600 text-5xl"></i>
            <h1 class="text-3xl font-bold text-gray-900 mt-3">HealtSync</h1>
            <p class="text-gray-500 mt-1">Sistema de Gestión Médica</p>
        </div>

        <!-- Card -->
        <div class="bg-white rounded-xl shadow-lg overflow-hidden">

            <div class="bg-gray-800 px-6 py-4">
                <h2 class="text-white text-lg font-semibold">
                    <i class="fas fa-lock mr-2"></i>
                    Iniciar Sesión
                </h2>
            </div>

            <div class="p-6">

                <!-- Error -->
                @if (!string.IsNullOrEmpty(ViewBag.ErrorMessage))
                {
                    <div class="mb-4 bg-red-100 border-l-4 border-red-500 text-red-700 p-4 rounded-lg">
                        <div class="flex items-center">
                            <i class="fas fa-exclamation-circle mr-2"></i>
                            <span>@ViewBag.ErrorMessage</span>
                        </div>
                    </div>
                }

                <form asp-action="Login" method="post">
                    @Html.AntiForgeryToken()

                    <div asp-validation-summary="ModelOnly"
                         class="mb-4 bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg text-sm"></div>

                    <!-- Email -->
                    <div class="mb-5">
                        <label asp-for="Email" class="block text-sm font-medium text-gray-700 mb-2">
                            Correo Electrónico
                        </label>
                        <div class="relative">
                            <span class="absolute inset-y-0 left-0 flex items-center pl-3 text-gray-400">
                                <i class="fas fa-envelope"></i>
                            </span>
                            <input asp-for="Email"
                                   type="email"
                                   class="w-full pl-10 pr-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition"
                                   placeholder="usuario@ejemplo.com"
                                   autofocus />
                        </div>
                        <span asp-validation-for="Email" class="text-sm text-red-600 mt-1 block"></span>
                    </div>

                    <!-- Password -->
                    <div class="mb-6">
                        <label asp-for="Password" class="block text-sm font-medium text-gray-700 mb-2">
                            Contraseña
                        </label>
                        <div class="relative">
                            <span class="absolute inset-y-0 left-0 flex items-center pl-3 text-gray-400">
                                <i class="fas fa-lock"></i>
                            </span>
                            <input asp-for="Password"
                                   type="password"
                                   id="passwordInput"
                                   class="w-full pl-10 pr-10 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition"
                                   placeholder="Ingrese su contraseña" />
                            <button type="button"
                                    onclick="togglePassword()"
                                    class="absolute inset-y-0 right-0 flex items-center pr-3 text-gray-400 hover:text-gray-600">
                                <i id="eyeIcon" class="fas fa-eye"></i>
                            </button>
                        </div>
                        <span asp-validation-for="Password" class="text-sm text-red-600 mt-1 block"></span>
                    </div>

                    <!-- Submit -->
                    <button type="submit"
                            class="w-full py-2.5 bg-blue-600 hover:bg-blue-700 text-white font-medium rounded-lg transition duration-200 shadow-md">
                        <i class="fas fa-sign-in-alt mr-2"></i>
                        Ingresar
                    </button>
                </form>
            </div>
        </div>

        <p class="text-center text-sm text-gray-500 mt-6">
            &copy; 2025 HealtSync — Todos los derechos reservados
        </p>
    </div>

    <script>
        function togglePassword() {
        const input = document.getElementById('passwordInput');
        const icon = document.getElementById('eyeIcon');
        if (input.type === 'password') {
        input.type = 'text';
        icon.classList.replace('fa-eye', 'fa-eye-slash');
        } else {
        input.type = 'password';
        icon.classList.replace('fa-eye-slash', 'fa-eye');
        }
        }
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>