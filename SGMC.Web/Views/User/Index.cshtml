@model IEnumerable<SGMC.Application.Dto.Users.UserDto>

@{
    ViewData["Title"] = "Usuarios";
}

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Título -->
    <div class="mb-8">
        <h1 class="text-3xl font-bold text-gray-900">Gestión de Usuarios</h1>
        <p class="text-gray-600 mt-2">Administra los usuarios del sistema y sus permisos</p>
    </div>

    <!-- Mensajes de error -->
    @if (!string.IsNullOrEmpty(ViewBag.ErrorMessage))
    {
        <div class="mb-4 bg-red-100 border-l-4 border-red-500 text-red-700 p-4 rounded-lg shadow-sm">
            <div class="flex items-center">
                <i class="fas fa-exclamation-circle mr-2 text-red-500"></i>
                <span>@ViewBag.ErrorMessage</span>
            </div>
        </div>
    }

    <!-- Botón Crear -->
    <div class="mb-6">
        <a asp-action="Create" class="inline-flex items-center px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white font-medium rounded-lg transition duration-200 ease-in-out transform hover:scale-105 shadow-md">
            <i class="fas fa-user-plus mr-2"></i>
            Crear Nuevo Usuario
        </a>
    </div>

    <!-- Tabla de Usuarios -->
    <div class="bg-white rounded-xl shadow-lg overflow-hidden">
        <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-gray-200">
                <thead class="bg-gray-800 text-white">
                    <tr>
                        <th class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wider">ID</th>
                        <th class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wider">Email</th>
                        <th class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wider">Rol</th>
                        <th class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wider">Activo</th>
                        <th class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wider">Fecha de Creación</th>
                        <th class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wider">Acciones</th>
                    </tr>
                </thead>
                <tbody class="bg-white divide-y divide-gray-200">
                    @foreach (var user in Model)
                    {
                        <tr class="hover:bg-gray-50 transition duration-150">
                            <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">
                                @user.UserId
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-700">
                                <div class="flex items-center">
                                    <i class="fas fa-envelope text-gray-400 mr-2"></i>
                                    @user.Email
                                </div>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-700">
                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-purple-100 text-purple-800">
                                    <i class="fas fa-user-tag mr-1 text-xs"></i>
                                    @user.RoleName
                                </span>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap">
                                @if (user.IsActive)
                                {
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                                        <span class="w-1.5 h-1.5 bg-green-500 rounded-full mr-1.5"></span>
                                        Activo
                                    </span>
                                }
                                else
                                {
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800">
                                        <span class="w-1.5 h-1.5 bg-red-500 rounded-full mr-1.5"></span>
                                        Inactivo
                                    </span>
                                }
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-700">
                                <div class="flex items-center">
                                    <i class="fas fa-calendar-alt text-gray-400 mr-2"></i>
                                    @user.CreatedAt?.ToString("dd/MM/yyyy")
                                </div>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm">
                                <div class="flex flex-wrap gap-2">
                                    <a asp-action="Edit" asp-route-id="@user.UserId"
                                       class="inline-flex items-center px-2.5 py-1.5 bg-yellow-500 hover:bg-yellow-600 text-white text-xs font-medium rounded transition"
                                       title="Editar">
                                        <i class="fas fa-edit mr-1"></i>
                                        Editar
                                    </a>
                                    <a asp-action="Details" asp-route-id="@user.UserId"
                                       class="inline-flex items-center px-2.5 py-1.5 bg-blue-500 hover:bg-blue-600 text-white text-xs font-medium rounded transition"
                                       title="Detalles">
                                        <i class="fas fa-info-circle mr-1"></i>
                                        Detalles
                                    </a>
                                    <a asp-action="ChangePassword" asp-route-id="@user.UserId"
                                       class="inline-flex items-center px-2.5 py-1.5 bg-gray-500 hover:bg-gray-600 text-white text-xs font-medium rounded transition"
                                       title="Cambiar Contraseña">
                                        <i class="fas fa-key mr-1"></i>
                                        Cambiar
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@user.UserId"
                                       class="inline-flex items-center px-2.5 py-1.5 bg-red-500 hover:bg-red-600 text-white text-xs font-medium rounded transition"
                                       title="Eliminar">
                                        <i class="fas fa-trash mr-1"></i>
                                        Eliminar
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Si no hay usuarios -->
        @if (!Model.Any())
        {
            <div class="text-center py-12 bg-gray-50">
                <i class="fas fa-users-slash text-5xl text-gray-400 mb-3 block"></i>
                <p class="text-gray-500 text-lg">No hay usuarios registrados</p>
                <p class="text-gray-400 text-sm mt-1">Comienza creando un nuevo usuario</p>
            </div>
        }
    </div>

    <!-- Contador de registros -->
    @if (Model.Any())
    {
        <div class="mt-4 text-sm text-gray-600 flex items-center justify-between">
            <div>
                <i class="fas fa-database mr-1"></i>
                Total de usuarios: <span class="font-semibold">@Model.Count()</span>
            </div>
            <div>
                <i class="fas fa-users mr-1"></i>
                Activos: <span class="font-semibold text-green-600">@Model.Count(u => u.IsActive)</span>
                | Inactivos: <span class="font-semibold text-red-600">@Model.Count(u => !u.IsActive)</span>
            </div>
        </div>
    }
</div>

@section Styles {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
}