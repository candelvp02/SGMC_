@model SGMC.Application.Dto.Users.UserDto

@{
    ViewData["Title"] = "Detalles del Usuario";
}

<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Título -->
    <div class="mb-8">
        <h1 class="text-3xl font-bold text-gray-900">Detalles del Usuario</h1>
        <p class="text-gray-600 mt-2">Información completa del usuario del sistema</p>
    </div>

    <!-- Mensajes de error -->
    @if (!string.IsNullOrEmpty(ViewBag.ErrorMessage))
    {
        <div class="mb-6 bg-red-100 border-l-4 border-red-500 text-red-700 p-4 rounded-lg shadow-sm">
            <div class="flex items-center">
                <svg class="w-5 h-5 mr-2 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <span>@ViewBag.ErrorMessage</span>
            </div>
        </div>
    }

    <!-- Tarjeta de Detalles -->
    <div class="bg-white rounded-xl shadow-lg overflow-hidden">
        <!-- Header de la tarjeta -->
        <div class="border-b border-gray-200 bg-gradient-to-r from-gray-50 to-gray-100 px-6 py-4">
            <h3 class="text-lg font-semibold text-gray-900">
                Información del Usuario
            </h3>
        </div>

        <!-- Cuerpo de la tarjeta -->
        <div class="p-6">
            <dl class="divide-y divide-gray-200">
                <!-- ID de Usuario -->
                <div class="py-4 flex flex-col sm:flex-row">
                    <dt class="sm:w-1/3 text-sm font-medium text-gray-500 mb-1 sm:mb-0">
                        ID de Usuario
                    </dt>
                    <dd class="sm:w-2/3 text-sm text-gray-900 font-mono">
                        @Model.UserId
                    </dd>
                </div>

                <!-- Email -->
                <div class="py-4 flex flex-col sm:flex-row">
                    <dt class="sm:w-1/3 text-sm font-medium text-gray-500 mb-1 sm:mb-0">
                        Correo Electrónico
                    </dt>
                    <dd class="sm:w-2/3 text-sm text-gray-900">
                        @Model.Email
                    </dd>
                </div>

                <!-- Rol -->
                <div class="py-4 flex flex-col sm:flex-row">
                    <dt class="sm:w-1/3 text-sm font-medium text-gray-500 mb-1 sm:mb-0">
                        Rol
                    </dt>
                    <dd class="sm:w-2/3">
                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-purple-100 text-purple-800">
                            @Model.RoleName
                        </span>
                    </dd>
                </div>

                <!-- Estado -->
                <div class="py-4 flex flex-col sm:flex-row">
                    <dt class="sm:w-1/3 text-sm font-medium text-gray-500 mb-1 sm:mb-0">
                        Estado
                    </dt>
                    <dd class="sm:w-2/3">
                        @if (Model.IsActive)
                        {
                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                                <span class="w-1.5 h-1.5 bg-green-500 rounded-full mr-1.5"></span>
                                Activo
                            </span>
                        }
                        else
                        {
                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800">
                                <span class="w-1.5 h-1.5 bg-red-500 rounded-full mr-1.5"></span>
                                Inactivo
                            </span>
                        }
                    </dd>
                </div>

                <!-- Fecha de Creación -->
                <div class="py-4 flex flex-col sm:flex-row">
                    <dt class="sm:w-1/3 text-sm font-medium text-gray-500 mb-1 sm:mb-0">
                        Fecha de Creación
                    </dt>
                    <dd class="sm:w-2/3 text-sm text-gray-900">
                        @Model.CreatedAt?.ToString("dd/MM/yyyy HH:mm")
                    </dd>
                </div>
            </dl>
        </div>
    </div>

    <!-- Botones de Acción -->
    <div class="mt-6 flex flex-wrap gap-3">
        <a asp-action="Edit" asp-route-id="@Model.UserId"
           class="inline-flex items-center px-4 py-2 bg-yellow-500 hover:bg-yellow-600 text-white font-medium rounded-lg transition duration-200 shadow-md">
            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
            </svg>
            Editar
        </a>

        <a asp-action="ChangePassword" asp-route-id="@Model.UserId"
           class="inline-flex items-center px-4 py-2 bg-gray-500 hover:bg-gray-600 text-white font-medium rounded-lg transition duration-200 shadow-md">
            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z" />
            </svg>
            Cambiar Contraseña
        </a>

        <a asp-action="Index"
           class="inline-flex items-center px-4 py-2 bg-gray-500 hover:bg-gray-600 text-white font-medium rounded-lg transition duration-200 shadow-md">
            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
            </svg>
            Volver a la Lista
        </a>
    </div>

    <!-- Tarjeta de Información Adicional (opcional) -->
    <div class="mt-8 bg-blue-50 border border-blue-200 rounded-lg p-4">
        <div class="flex items-start">
            <svg class="w-5 h-5 text-blue-500 mt-0.5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <div>
                <h4 class="text-sm font-semibold text-blue-800">Información del Sistema</h4>
                <p class="text-sm text-blue-600 mt-1">
                    Para cambiar la contraseña o desactivar este usuario, utilice los botones de acción disponibles.
                </p>
            </div>
        </div>
    </div>
</div>