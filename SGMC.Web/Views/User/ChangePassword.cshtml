@model SGMC.Application.Dto.System.ChangePasswordDto

@{
    ViewData["Title"] = "Cambiar Contraseña";
}

<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Título -->
    <div class="mb-8">
        <h1 class="text-3xl font-bold text-gray-900">Cambiar Contraseña</h1>
        <p class="text-gray-600 mt-2">Actualice la contraseña de su cuenta</p>
    </div>

    <!-- Mensajes de error y éxito -->
    @if (!string.IsNullOrEmpty(ViewBag.ErrorMessage))
    {
        <div class="mb-6 bg-red-100 border-l-4 border-red-500 text-red-700 p-4 rounded-lg shadow-sm">
            <div class="flex items-center">
                <svg class="w-5 h-5 mr-2 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <span>@ViewBag.ErrorMessage</span>
            </div>
        </div>
    }

    @if (!string.IsNullOrEmpty(ViewBag.SuccessMessage))
    {
        <div class="mb-6 bg-green-100 border-l-4 border-green-500 text-green-700 p-4 rounded-lg shadow-sm">
            <div class="flex items-center">
                <svg class="w-5 h-5 mr-2 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <span>@ViewBag.SuccessMessage</span>
            </div>
        </div>
    }

    <!-- Formulario -->
    <div class="bg-white rounded-xl shadow-lg overflow-hidden">
        <!-- Header -->
        <div class="border-b border-gray-200 bg-gradient-to-r from-gray-50 to-gray-100 px-6 py-4">
            <h3 class="text-lg font-semibold text-gray-900">
                Formulario de Cambio de Contraseña
            </h3>
        </div>

        <!-- Cuerpo del formulario -->
        <div class="p-6">
            <form asp-action="ChangePassword">
                <input type="hidden" asp-for="UserId" />

                <!-- Resumen de validación -->
                <div asp-validation-summary="ModelOnly" class="mb-4 bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg text-sm"></div>

                <!-- Contraseña Actual -->
                <div class="mb-6">
                    <label asp-for="CurrentPassword" class="block text-sm font-medium text-gray-700 mb-2">
                        Contraseña Actual
                        <span class="text-red-500 ml-1">*</span>
                    </label>
                    <input asp-for="CurrentPassword"
                           type="password"
                           class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition @(ViewData.ModelState.ContainsKey("CurrentPassword") && ViewData.ModelState["CurrentPassword"].Errors.Any() ? "border-red-500" : "")"
                           placeholder="Ingrese su contraseña actual"
                           required />
                    <span asp-validation-for="CurrentPassword" class="text-sm text-red-600 mt-1 block"></span>
                    <p class="text-xs text-gray-500 mt-1">Debe ingresar su contraseña actual para realizar el cambio</p>
                </div>

                <!-- Nueva Contraseña -->
                <div class="mb-6">
                    <label asp-for="NewPassword" class="block text-sm font-medium text-gray-700 mb-2">
                        Nueva Contraseña
                        <span class="text-red-500 ml-1">*</span>
                    </label>
                    <input asp-for="NewPassword"
                           type="password"
                           id="NewPassword"
                           class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition @(ViewData.ModelState.ContainsKey("NewPassword") && ViewData.ModelState["NewPassword"].Errors.Any() ? "border-red-500" : "")"
                           placeholder="Ingrese una nueva contraseña segura"
                           required />
                    <span asp-validation-for="NewPassword" class="text-sm text-red-600 mt-1 block"></span>

                    <!-- Requisitos de seguridad -->
                    <div class="mt-3 bg-gray-50 rounded-lg p-3 border border-gray-200">
                        <p class="text-xs font-medium text-gray-700 mb-2">Requisitos de seguridad:</p>
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
                            <div class="flex items-center">
                                <svg id="lengthIcon" class="w-4 h-4 mr-2 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                                </svg>
                                <span id="lengthText" class="text-xs text-gray-500">Mínimo 8 caracteres</span>
                            </div>
                            <div class="flex items-center">
                                <svg id="uppercaseIcon" class="w-4 h-4 mr-2 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                                </svg>
                                <span id="uppercaseText" class="text-xs text-gray-500">Al menos una mayúscula</span>
                            </div>
                            <div class="flex items-center">
                                <svg id="lowercaseIcon" class="w-4 h-4 mr-2 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                                </svg>
                                <span id="lowercaseText" class="text-xs text-gray-500">Al menos una minúscula</span>
                            </div>
                            <div class="flex items-center">
                                <svg id="numberIcon" class="w-4 h-4 mr-2 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                                </svg>
                                <span id="numberText" class="text-xs text-gray-500">Al menos un número</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Indicador de fortaleza de la contraseña -->
                <div class="mb-6">
                    <div class="flex justify-between items-center mb-1">
                        <span class="text-xs font-medium text-gray-700">Fortaleza de la contraseña:</span>
                        <span id="strengthText" class="text-xs font-medium text-gray-500">Sin evaluar</span>
                    </div>
                    <div class="w-full bg-gray-200 rounded-full h-2">
                        <div id="strengthBar" class="bg-gray-400 h-2 rounded-full transition-all duration-300" style="width: 0%"></div>
                    </div>
                </div>

                <!-- Botones de acción -->
                <div class="flex flex-wrap gap-3 pt-4 border-t border-gray-200">
                    <button type="submit" class="inline-flex items-center px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white font-medium rounded-lg transition duration-200 shadow-md">
                        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z" />
                        </svg>
                        Cambiar Contraseña
                    </button>
                    <a asp-action="Index" class="inline-flex items-center px-4 py-2 bg-gray-500 hover:bg-gray-600 text-white font-medium rounded-lg transition duration-200 shadow-md">
                        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                        </svg>
                        Cancelar
                    </a>
                </div>
            </form>
        </div>
    </div>

    <!-- Consejos de seguridad -->
    <div class="mt-6 grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
            <div class="flex items-start">
                <svg class="w-5 h-5 text-blue-500 mt-0.5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <div>
                    <h4 class="text-sm font-semibold text-blue-800">Recomendaciones de seguridad</h4>
                    <ul class="text-sm text-blue-600 mt-1 space-y-1 list-disc list-inside">
                        <li>No use la misma contraseña en múltiples sitios</li>
                        <li>Evite usar información personal (fechas, nombres)</li>
                        <li>Cambie su contraseña regularmente</li>
                    </ul>
                </div>
            </div>
        </div>

        <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-4">
            <div class="flex items-start">
                <svg class="w-5 h-5 text-yellow-600 mt-0.5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                </svg>
                <div>
                    <h4 class="text-sm font-semibold text-yellow-800">Nota importante</h4>
                    <p class="text-sm text-yellow-700 mt-1">
                        Después de cambiar su contraseña, deberá usarla en el próximo inicio de sesión.
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        // Validador de fortaleza de contraseña en tiempo real
        const passwordInput = document.getElementById('NewPassword');

        function validatePasswordStrength(password) {
            const checks = {
                length: password.length >= 8,
                uppercase: /[A-Z]/.test(password),
                lowercase: /[a-z]/.test(password),
                number: /[0-9]/.test(password)
            };

            // Actualizar iconos y textos
            updateCheck('length', checks.length);
            updateCheck('uppercase', checks.uppercase);
            updateCheck('lowercase', checks.lowercase);
            updateCheck('number', checks.number);

            // Calcular fortaleza (0-4)
            const strength = Object.values(checks).filter(Boolean).length;

            // Actualizar barra y texto de fortaleza
            const strengthBar = document.getElementById('strengthBar');
            const strengthText = document.getElementById('strengthText');

            if (strength === 0) {
                strengthBar.style.width = '0%';
                strengthBar.className = 'bg-gray-400 h-2 rounded-full transition-all duration-300';
                strengthText.textContent = 'Sin evaluar';
                strengthText.className = 'text-xs font-medium text-gray-500';
            } else if (strength <= 2) {
                strengthBar.style.width = '25%';
                strengthBar.className = 'bg-red-500 h-2 rounded-full transition-all duration-300';
                strengthText.textContent = 'Débil';
                strengthText.className = 'text-xs font-medium text-red-600';
            } else if (strength === 3) {
                strengthBar.style.width = '50%';
                strengthBar.className = 'bg-yellow-500 h-2 rounded-full transition-all duration-300';
                strengthText.textContent = 'Media';
                strengthText.className = 'text-xs font-medium text-yellow-600';
            } else if (strength === 4) {
                strengthBar.style.width = '100%';
                strengthBar.className = 'bg-green-500 h-2 rounded-full transition-all duration-300';
                strengthText.textContent = 'Fuerte';
                strengthText.className = 'text-xs font-medium text-green-600';
            }

            return checks.length && checks.uppercase && checks.lowercase && checks.number;
        }

        function updateCheck(type, isValid) {
            const icon = document.getElementById(`${type}Icon`);
            const text = document.getElementById(`${type}Text`);

            if (isValid) {
                icon.classList.remove('text-gray-400');
                icon.classList.add('text-green-500');
                text.classList.remove('text-gray-500');
                text.classList.add('text-green-600');
            } else {
                icon.classList.remove('text-green-500');
                icon.classList.add('text-gray-400');
                text.classList.remove('text-green-600');
                text.classList.add('text-gray-500');
            }
        }

        if (passwordInput) {
            passwordInput.addEventListener('input', function() {
                validatePasswordStrength(this.value);
            });
        }
    </script>
}